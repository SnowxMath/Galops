# Fournisseur de stockage de la progression.
# "local" (défaut) = localStorage, hors-ligne, sans compte.
# "supabase" = sync multi-appareils (à implémenter, cf. README).
NEXT_PUBLIC_STORAGE_PROVIDER=local

